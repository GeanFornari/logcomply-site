---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout 
  title="Vektor Aero — Ecossistema Digital para a Aviação Brasileira"
  description="Ferramentas aeronáuticas indispensáveis. Controle sua jornada e fadiga com o Journey Comply e tenha todo o ROTAER e cartas à mão com o AIS BR."
>
  <div class="w-full bg-[#0B1726]">
    <Header />

    <!-- HERO -->
    <main class="relative w-full flex items-center py-24 sm:py-32">

      <div class="absolute inset-0 z-0">
        <img src="/horizonte.png" alt="Pista de decolagem ao entardecer" class="w-full h-full object-cover object-center" />
        <!-- OVERLAY: ajuste opacity-XX para controlar escuridão. opacity-60 = mais claro, opacity-90 = mais escuro -->
        <div class="absolute inset-0 bg-[#0B1726] opacity-65"></div>
      </div>

      <div class="relative z-10 flex flex-col items-center text-center w-full max-w-5xl mx-auto px-6 lg:px-8 gap-6">

        <img src="/logo.png" alt="Vektor Aero" class="h-20 w-auto mb-2" />

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight text-gray-100">
          Seu destino, nossa tecnologia
        </h1>

        <p class="text-xl md:text-2xl text-gray-300 max-w-3xl">
          Da inteligência aeronáutica ao controle das suas operações.<br />
          Precisão de cockpit aplicada à sua rotina.
        </p>

        <a href="#solucoes" class="mt-4 inline-flex items-center gap-2 bg-white/10 hover:bg-white/20 border border-white/20 text-white font-semibold px-6 py-3 rounded-full transition-all hover:scale-105">
          Conheça nossas soluções
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
        </a>

      </div>
    </main>

    <!-- SOLUÇÕES -->
    <section id="solucoes" class="bg-white py-16 sm:py-24">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">

        <div class="text-center mb-16">
          <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-gray-900">Nossas Soluções</h2>
          <p class="mt-4 text-lg text-gray-600 max-w-2xl mx-auto">
            Ferramentas independentes, construídas com o mesmo rigor — para quem precisa de resultados, não de complexidade.
          </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

          <!-- Journey Comply -->
          <div class="group relative flex flex-col rounded-3xl overflow-hidden border border-gray-200 shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-1">
            <div class="bg-[#0B1726] px-8 pt-10 pb-6">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <span class="inline-block bg-blue-500/20 text-blue-300 text-xs font-bold px-3 py-1 rounded-full tracking-widest mb-3">RBAC 117 · LEI 13.475</span>
                  <h3 class="text-3xl font-bold text-white">Journey Comply</h3>
                  <p class="mt-2 text-gray-400 text-base">Gerenciamento de Fadiga e Jornada</p>
                </div>
                <img src="/tela1.jpg" alt="Interface do app Journey Comply demonstrando funcionalidades de cálculo de jornada em miniatura" class="w-32 flex-shrink-0 drop-shadow-xl -mt-2 group-hover:scale-105 transition-transform duration-300" />
              </div>
            </div>
            <div class="flex flex-col flex-1 bg-white px-8 py-6">
              <ul class="space-y-3 text-gray-600 flex-1">
                <li class="flex items-center gap-3">
                  <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  Planejamento de jornada baseado em RBAC 117
                </li>
                <li class="flex items-center gap-3">
                  <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  Multiplataforma: iOS e Android, celular e tablet
                </li>
                <li class="flex items-center gap-3">
                  <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  Ferramentas essenciais: Time Zones, METAR, Conversor
                </li>
                <li class="flex items-center gap-3">
                  <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  Para pilotos e comissários de bordo
                </li>
              </ul>
              <div class="mt-8 flex flex-col sm:flex-row gap-3">
                <a href="https://apps.apple.com/br/app/journey-comply/id6754107539" target="_blank" rel="noopener noreferrer" class="transition-transform hover:scale-105">
                  <img src="/baixar-na-app-store.png" alt="Baixar na App Store" class="h-11 w-auto" />
                </a>
                <a href="https://play.google.com/store/apps/details?id=br.com.vektoraero.journeycomply" target="_blank" rel="noopener noreferrer" class="transition-transform hover:scale-105 play-store-link-jc">
                  <img src="/baixar-na-google-play.png" alt="Baixar na Google Play" class="h-11 w-auto" />
                </a>
              </div>
              <a href="/journeycomply/" class="mt-5 inline-flex items-center gap-1 text-blue-700 font-semibold hover:text-blue-900 transition-colors text-sm">
                Ver página completa
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
              </a>
            </div>
          </div>

          <!-- AIS BR -->
          <div class="group relative flex flex-col rounded-3xl overflow-hidden border border-gray-200 shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-1">
            <div class="bg-[#0B1726] px-8 pt-10 pb-6">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <span class="inline-block bg-cyan-500/20 text-cyan-300 text-xs font-bold px-3 py-1 rounded-full tracking-widest mb-3">AISWEB · DECEA · REDEMET</span>
                  <h3 class="text-3xl font-bold text-white">AIS BR</h3>
                  <p class="mt-2 text-gray-400 text-base">Informação Aeronáutica Oficial</p>
                </div>
                <!-- iPhone frame inline — imagem mantém w-32 -->
                <img src="/aisbr-card.png" alt="Interface do app AIS BR em miniatura apresentando o acesso rápido a informações aeronáuticas" class="w-32 flex-shrink-0 drop-shadow-xl -mt-2 group-hover:scale-105 transition-transform duration-300" />

              </div>
            </div>
            <div class="flex flex-col flex-1 bg-white px-8 py-6">
              <ul class="space-y-3 text-gray-600 flex-1">
                <li class="flex items-center gap-3">
                  <svg class="w-5 h-5 text-cyan-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  ROTAER completo — disponível offline
                </li>
                <li class="flex items-center gap-3">
                  <svg class="w-5 h-5 text-cyan-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  METAR/TAF, NOTAMs e Suplementos em tempo real
                </li>
                <li class="flex items-center gap-3">
                  <svg class="w-5 h-5 text-cyan-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  Busca de aeródromos próximos com mapa
                </li>
                <li class="flex items-center gap-3">
                  <svg class="w-5 h-5 text-cyan-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  Briefing de voo completo: ROTAER, METAR/TAF e NOTAMs
                </li>
              </ul>
              <div class="mt-8 flex flex-col sm:flex-row gap-3">
                <a href="https://apps.apple.com/us/app/ais-br/id6755229539" target="_blank" rel="noopener noreferrer" class="transition-transform hover:scale-105 app-store-link-aisbr">
                  <img src="/baixar-na-app-store.png" alt="Baixar na App Store" class="h-11 w-auto" />
                </a>
                <a href="https://play.google.com/store/apps/details?id=com.vektoraero.aisbr" target="_blank" rel="noopener noreferrer" class="transition-transform hover:scale-105 play-store-link-aisbr">
                  <img src="/baixar-na-google-play.png" alt="Baixar na Google Play" class="h-11 w-auto" />
                </a>
              </div>
              <a href="/aisbr/" class="mt-5 inline-flex items-center gap-1 text-blue-700 font-semibold hover:text-blue-900 transition-colors text-sm">
                Ver página completa
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
              </a>
            </div>
          </div>

          <!-- KontrolSub -->
          <div class="group relative flex flex-col rounded-3xl overflow-hidden border border-gray-200 shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-1">
            <div class="bg-[#152626] px-8 pt-10 pb-6">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <span class="inline-block bg-teal-400/20 text-teal-300 text-xs font-bold px-3 py-1 rounded-full tracking-widest mb-3">iOS · Android</span>
                  <h3 class="text-3xl font-bold text-white">KontrolSub</h3>
                  <p class="mt-2 text-gray-400 text-base">Gestão de Assinaturas Digitais</p>
                </div>
                <img src="/kontrolsub/app/pt/dashboard.png" alt="Interface do app KontrolSub exibindo o dashboard de controle de assinaturas e gastos mensais" class="w-32 flex-shrink-0 drop-shadow-xl -mt-2 group-hover:scale-105 transition-transform duration-300" />
              </div>
            </div>
            <div class="flex flex-col flex-1 bg-white px-8 py-6">
              <ul class="space-y-3 text-gray-600 flex-1">
                <li class="flex items-center gap-3">
                  <svg class="w-5 h-5 text-teal-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  Centralize todas as suas assinaturas em um só lugar
                </li>
                <li class="flex items-center gap-3">
                  <svg class="w-5 h-5 text-teal-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  Alertas de renovação e análise de gastos
                </li>
                <li class="flex items-center gap-3">
                  <svg class="w-5 h-5 text-teal-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  Disponível em 5 idiomas
                </li>
                <li class="flex items-center gap-3">
                  <svg class="w-5 h-5 text-teal-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  Calendário mensal de vencimentos
                </li>
              </ul>
              <div class="mt-8 flex flex-col sm:flex-row gap-3">
                <a href="https://apps.apple.com/app/kontrolsub-subs-tracker/id6760716794" target="_blank" rel="noopener noreferrer" class="transition-transform hover:scale-105 app-store-link-ks">
                  <img src="/baixar-na-app-store.png" alt="Baixar na App Store" class="h-11 w-auto" />
                </a>
                <a href="https://play.google.com/store/apps/details?id=com.vektordigital.kontrol_app&hl=pt_BR" target="_blank" rel="noopener noreferrer" class="transition-transform hover:scale-105">
                  <img src="/baixar-na-google-play.png" alt="Baixar na Google Play" class="h-11 w-auto" />
                </a>
              </div>
              <a href="/kontrolsub/" class="mt-5 inline-flex items-center gap-1 text-teal-700 font-semibold hover:text-teal-900 transition-colors text-sm">
                Ver página completa
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
              </a>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- SOBRE -->
    <section id="sobre" class="bg-gray-50 py-16 sm:py-24">
      <div class="mx-auto max-w-7xl px-6 lg:px-8 text-center">

        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-gray-900">
          Construído por quem enfrenta o problema, para quem precisa de resultado
        </h2>

        <p class="mt-6 max-w-3xl mx-auto text-lg leading-8 text-gray-600">
          A aviação exige precisão onde não há margem para erro. Foi essa experiência — como piloto e como usuário frustrado — que levou <span class="font-semibold text-blue-900">Geancarlo Fornari</span> a criar a Vektor Aero: software construído com o mesmo rigor que a cabine exige, aplicado a problemas reais de quem opera.
        </p>

        <div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-12">

          <div class="flex flex-col items-center">
            <div class="flex items-center justify-center h-16 w-16 rounded-full bg-blue-100">
              <svg class="h-8 w-8 text-blue-900" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
              </svg>
            </div>
            <h3 class="mt-5 text-xl font-semibold text-gray-900">Precisão Inquestionável</h3>
            <p class="mt-2 text-base text-gray-600">
              Cada dado e cada lógica é baseada em fontes confiáveis. Nada de aproximações.
            </p>
          </div>

          <div class="flex flex-col items-center">
            <div class="flex items-center justify-center h-16 w-16 rounded-full bg-blue-100">
              <svg class="h-8 w-8 text-blue-900" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 0 0 6 3.75v16.5a2.25 2.25 0 0 0 2.25 2.25h7.5A2.25 2.25 0 0 0 18 20.25V3.75a2.25 2.25 0 0 0-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" />
              </svg>
            </div>
            <h3 class="mt-5 text-xl font-semibold text-gray-900">Design para Quem Não Tem Tempo a Perder</h3>
            <p class="mt-2 text-base text-gray-600">
              Interface direta, sem ruído. Projetada para decisões rápidas em contextos de alta pressão.
            </p>
          </div>

          <div class="flex flex-col items-center">
            <div class="flex items-center justify-center h-16 w-16 rounded-full bg-blue-100">
              <svg class="h-8 w-8 text-blue-900" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
              </svg>
            </div>
            <h3 class="mt-5 text-xl font-semibold text-gray-900">Confiável por Padrão</h3>
            <p class="mt-2 text-base text-gray-600">
              Software que funciona quando você precisa — sem surpresas, sem instabilidade, sem desculpas.
            </p>
          </div>

        </div>

        <div class="mt-12">
          <a href="/sobre-nos/" class="inline-flex items-center gap-2 text-blue-700 font-semibold hover:text-blue-900 transition-colors">
            Conheça nossa história
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- CONTATO / NEWSLETTER -->
    <section id="contato" class="bg-[#0B1726] py-16 sm:py-24">
      <div class="mx-auto max-w-7xl px-6 lg:px-8 text-center">

        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-white">
          Fique por dentro das atualizações da Vektor Aero
        </h2>

        <p class="mt-4 max-w-2xl mx-auto text-lg leading-8 text-gray-300">
          Receba novidades, dicas operacionais e conteúdos exclusivos direto no seu e-mail.
        </p>

        <div class="mt-10 flex items-center justify-center">
          <form
            id="newsletter-form"
            action="https://assets.mailerlite.com/jsonp/1832091/forms/167158902571402524/subscribe"
            method="POST"
            class="flex flex-col sm:flex-row gap-4 w-full max-w-md"
          >
            <input type="hidden" name="ml-submit" value="1" />
            <input type="hidden" name="anticsrf" value="true" />

            <label for="email-address" class="sr-only">Endereço de e-mail</label>
            <input
              id="email-address"
              name="fields[email]"
              type="email"
              autocomplete="email"
              required
              class="flex-auto rounded-md border-0 bg-white/10 px-3.5 py-2 text-white shadow-sm ring-1 ring-inset ring-white/10 focus:ring-2 focus:ring-inset focus:ring-green-400 sm:text-sm sm:leading-6"
              placeholder="Digite seu melhor e-mail"
            />

            <button
              type="submit"
              class="flex-none rounded-md bg-green-500 px-3.5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-green-400 transition-colors"
            >
              Cadastrar
            </button>
          </form>
        </div>

        <script>
          document.getElementById('newsletter-form')?.addEventListener('submit', async function(e) {
            e.preventDefault();
            const form = e.target as HTMLFormElement;
            const formData = new FormData(form);
            try {
              await fetch(form.action, { method: 'POST', body: formData, mode: 'no-cors' });
              window.location.href = '/obrigado/';
            } catch {
              window.location.href = '/obrigado/';
            }
          });
        </script>

        <script is:inline>
          function setupStoreRedirection() {
            // Redirecionamento Play Store (Android)
            const playConfigs = [
              { selector: '.play-store-link-aisbr', package: 'com.vektoraero.aisbr' },
              { selector: '.play-store-link-jc', package: 'br.com.vektoraero.journeycomply' }
            ];

            playConfigs.forEach(config => {
              const links = document.querySelectorAll(config.selector);
              links.forEach(link => {
                link.addEventListener('click', function(e) {
                  const isAndroid = /Android/i.test(navigator.userAgent);

                  if (isAndroid) {
                    e.preventDefault();
                    window.location.href = `market://details?id=${config.package}`;

                    setTimeout(() => {
                      window.location.href = `https://play.google.com/store/apps/details?id=${config.package}`;
                    }, 500);
                  }
                });
              });
            });

            // Redirecionamento App Store (iOS)
            const appStoreConfigs = [
              { selector: '.app-store-link-aisbr', appId: 'id6755229539', path: '/us/app/ais-br/id6755229539' },
              { selector: '.app-store-link-jc', appId: 'id6754107539', path: '/br/app/journey-comply/id6754107539' },
              { selector: '.app-store-link-ks', appId: 'id6760716794', path: '/app/kontrolsub-subs-tracker/id6760716794' }
            ];

            appStoreConfigs.forEach(config => {
              const links = document.querySelectorAll(config.selector);
              links.forEach(link => {
                link.addEventListener('click', function(e) {
                  const isIOS = /iPhone|iPad|iPod/i.test(navigator.userAgent);

                  if (isIOS) {
                    e.preventDefault();
                    window.location.href = `itms-apps://apps.apple.com${config.path}`;

                    setTimeout(() => {
                      window.location.href = `https://apps.apple.com${config.path}`;
                    }, 500);
                  }
                });
              });
            });
          }

          // Executa na carga inicial
          setupStoreRedirection();

          // Compatibilidade com View Transitions do Astro (se habilitado)
          document.addEventListener('astro:page-load', setupStoreRedirection);
        </script>

        <div class="mt-12 border-t border-white/10 pt-8">
          <p class="text-center text-gray-400 mb-4">Para parcerias, sugestões ou dúvidas, fale conosco:</p>

          <div class="text-center mb-6">
            <a href="mailto:contato@vektoraero.com.br" class="inline-flex items-center gap-2 text-xl font-semibold text-green-400 hover:text-green-300 transition-colors">
              <svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
              </svg>
              contato@vektoraero.com.br
            </a>
          </div>

          <p class="text-center text-gray-400 text-sm mb-6">Ou nos acompanhe nas redes sociais:</p>

          <div class="flex items-center justify-center gap-x-8">
            <a href="https://www.facebook.com/vektoraero/" target="_blank" rel="noopener noreferrer" title="Facebook" class="hover:opacity-80 transition-opacity">
              <span class="sr-only">Facebook</span>
              <img src="/facebook-icon.png" alt="Facebook" class="h-10 w-10 rounded-lg" />
            </a>
            <a href="https://www.instagram.com/VektorAero" target="_blank" rel="noopener noreferrer" title="Instagram" class="hover:opacity-80 transition-opacity">
              <span class="sr-only">Instagram</span>
              <img src="/insta-icon.jpg" alt="Instagram" class="h-10 w-10 rounded-lg" />
            </a>
            <a href="https://www.youtube.com/@VektorAero" target="_blank" rel="noopener noreferrer" title="YouTube" class="hover:opacity-80 transition-opacity">
              <span class="sr-only">YouTube</span>
              <img src="/youtube.png" alt="YouTube" class="h-10 w-10 rounded-lg" />
            </a>
