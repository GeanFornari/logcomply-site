---
import '../styles/kontrolsub.css';
import { getLangFromUrl, useTranslations } from '../i18n/kontrolsub/utils';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const {
  title,
  description = t('seo.description'),
  image = '/kontrolsub/og-image.png',
} = Astro.props;

const cleanPathname = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
const canonicalURL = new URL(cleanPathname, Astro.site || 'https://vektoraero.com.br');
const locales = ['pt', 'en', 'es', 'fr', 'de'];

const ogLocaleMap: Record<string, string> = { pt: 'pt_BR', en: 'en_US', es: 'es_ES', fr: 'fr_FR', de: 'de_DE' };
const ogLocale = ogLocaleMap[lang] ?? 'pt_BR';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO hreflang -->
    {locales.map((locale) => {
      const base = Astro.url.pathname.replace(/^\/kontrolsub\/(?:pt|en|es|fr|de)/, '');
      const localizedPath = `/kontrolsub/${locale}${base || '/'}`.replace(/\/+/g, '/');
      return <link rel="alternate" hreflang={locale} href={new URL(localizedPath, Astro.site)} />;
    })}
    <link rel="alternate" hreflang="x-default" href={new URL('/kontrolsub/pt/', Astro.site)} />

    <!-- Primary Meta -->
    <title>{title} | KontrolSub</title>
    <meta name="title" content={`${title} | KontrolSub`} />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Vektor Aero" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | KontrolSub`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />
    <meta property="og:image:alt" content="KontrolSub — Gestão de Assinaturas Digitais" />
    <meta property="og:site_name" content="Vektor Aero" />
    <meta property="og:locale" content={ogLocale} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={`${title} | KontrolSub`} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.site)} />
    <meta property="twitter:image:alt" content="KontrolSub — Gestão de Assinaturas Digitais" />

    <!-- Structured Data -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "KontrolSub",
      "operatingSystem": "iOS, Android",
      "applicationCategory": "FinanceApplication",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "description": "Gestão de assinaturas digitais com alertas de renovação, análise de gastos e calendário de vencimentos.",
      "url": "https://vektoraero.com.br/kontrolsub/",
      "author": {
        "@type": "Organization",
        "name": "Vektor Aero",
        "url": "https://vektoraero.com.br/"
      }
    })}></script>
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Início", "item": "https://vektoraero.com.br/" },
        { "@type": "ListItem", "position": 2, "name": "KontrolSub", "item": "https://vektoraero.com.br/kontrolsub/" }
      ]
    })}></script>

    <!-- Inter font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet" />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-J827Z0SRQ2"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', 'G-J827Z0SRQ2');
    </script>
  </head>
  <body>
    <slot />
  </body>
  <script>
    const observer = new IntersectionObserver(
      (entries) => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('reveal-visible'); }),
      { threshold: 0.1 }
    );
    document.querySelectorAll('section').forEach(s => { s.classList.add('reveal'); observer.observe(s); });
  </script>
</html>

<style>
  html, body { margin: 0; width: 100%; height: 100%; }
</style>
