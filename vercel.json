{
  "cleanUrls": true,
  "trailingSlash": true,
  "redirects": [
    {
      "source": "/kontrolsub",
      "destination": "/kontrolsub/pt/",
      "permanent": true
    },
    {
      "source": "/kontrolsub/",
      "destination": "/kontrolsub/pt/",
      "permanent": true
    },
    {
      "source": "/:lang(pt|en|es|fr|de)/kontrolsub/legal/:document",
      "destination": "/kontrolsub/:lang/legal/:document/",
      "permanent": true
    },
    {
      "source": "/:lang(pt|en|es|fr|de)/kontrolsub",
      "destination": "/kontrolsub/:lang/",
      "permanent": true
    },
    {
      "source": "/:lang(pt|en|es|fr|de)/kontrolsub/",
      "destination": "/kontrolsub/:lang/",
      "permanent": true
    },
    {
      "source": "/:lang(pt|en|es|fr|de)",
      "destination": "/kontrolsub/:lang/",
      "permanent": true
    },
    {
      "source": "/:lang(pt|en|es|fr|de)/",
      "destination": "/kontrolsub/:lang/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/(fonts|images)/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
