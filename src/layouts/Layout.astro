---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  schemaType?: 'Organization' | 'SoftwareApplication' | 'AboutPage';
  schemaData?: Record<string, any>;
}
const {
  title = "Vektor Aero — Tecnologia Mobile para Aviação e Vida Digital",
  description = "Tecnologia mobile de alta performance para aviação e vida digital. Journey Comply, AIS BR e KontrolSub — apps desenvolvidos com o rigor de quem não pode errar.",
  ogImage = "https://vektoraero.com.br/og-image.png",
  schemaType = "Organization",
  schemaData,
} = Astro.props as Props;

// Normalize canonical URL - ensure trailing slash for consistency with astro.config.mjs
const cleanPathname = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
const canonicalURL = new URL(cleanPathname, Astro.site || 'https://vektoraero.com.br').href;

const baseSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Vektor Aero",
  "url": "https://vektoraero.com.br/",
  "logo": "https://vektoraero.com.br/logo.png",
  "description": "Empresa brasileira de tecnologia mobile especializada em apps para aviação e vida digital — Journey Comply, AIS BR e KontrolSub.",
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "",
    "contactType": "customer service",
    "email": "contato@vektoraero.com.br"
  },
  "sameAs": [
    "https://www.facebook.com/vektoraero/",
    "https://www.instagram.com/VektorAero",
    "https://www.youtube.com/@VektorAero"
  ]
};

// Breadcrumb Schema for rich snippets
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Início",
      "item": "https://vektoraero.com.br/"
    },
    ...(Astro.url.pathname !== '/' && Astro.url.pathname !== '' ? [
      {
        "@type": "ListItem",
        "position": 2,
        "name": title.split(' — ')[0].split(' - ')[0],
        "item": canonicalURL
      }
    ] : [])
  ]
};

const finalSchemas = [
  baseSchema,
  breadcrumbSchema,
  ...(schemaData ? [{ "@context": "https://schema.org", "@type": schemaType, ...schemaData }] : [])
];

---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Vektor Aero" />
    <meta
      name="keywords"
      content="Vektor Aero, Journey Comply, AIS BR, KontrolSub, Gerenciamento de Fadiga, fadiga aeronautas, RBAC 117, jornada de voo, Lei do Aeronauta, app para pilotos, conformidade aérea, gestão de assinaturas, controle financeiro digital, aplicativo para tripulação"
    />
    
    <!-- Open Graph / Facebook / WhatsApp -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Vektor Aero — Tecnologia Mobile para Aviação e Vida Digital" />
    <meta property="og:site_name" content="Vektor Aero" />
    <meta property="og:locale" content="pt_BR" />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />
    <meta property="twitter:image:alt" content="Vektor Aero — Tecnologia Mobile para Aviação e Vida Digital" />
    
    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Favicons -->
    <link rel="icon" type="image/png" href="/favicon.png" />
    
    <!-- Preconnect for performance -->
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link rel="preconnect" href="https://assets.mailerlite.com" />
    
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    
    <!-- Structured Data -->
    {finalSchemas.map(schema => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
    ))}
    
    <!-- Google tag (gtag.js) - Unificado Analytics e Google Ads -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=AW-1005182629" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());

      // Configuração Google Analytics
      gtag('config', 'G-J827Z0SRQ2');
      // Configuração Google Ads
      gtag('config', 'AW-1005182629');
    </script>
  </head>
  <body class="bg-[#0B1726] text-gray-200 antialiased">
    <slot />
  </body>
</html>

<style is:global>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
    overflow-x: hidden;
  }
</style>
