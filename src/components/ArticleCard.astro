---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  category: 'journey-comply' | 'aisbr' | 'kontrolsub' | 'aviacao';
  tags: string[];
  image?: { src: string; alt: string };
  href: string;
  readingTime?: number;
}

const { title, description, pubDate, category, tags, image, href, readingTime } = Astro.props;

const categoryLabel: Record<string, string> = {
  'journey-comply': 'Journey Comply',
  'aisbr': 'AIS BR',
  'kontrolsub': 'KontrolSub',
  'aviacao': 'Aviação',
};

const categoryColor: Record<string, string> = {
  'journey-comply': 'bg-sky-500/10 text-sky-400 border-sky-500/20',
  'aisbr': 'bg-cyan-500/10 text-cyan-400 border-cyan-500/20',
  'kontrolsub': 'bg-teal-500/10 text-teal-400 border-teal-500/20',
  'aviacao': 'bg-indigo-500/10 text-indigo-400 border-indigo-500/20',
};

const formatDate = (date: Date) =>
  date.toLocaleDateString('pt-BR', { day: 'numeric', month: 'short', year: 'numeric' });
---

<a href={href} class="group block glass rounded-2xl overflow-hidden hover:border-white/20 transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl">
  {image && (
    <div class="overflow-hidden h-48">
      <img
        src={image.src}
        alt={image.alt}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
      />
    </div>
  )}

  <div class="p-6">
    <div class="flex items-center gap-3 mb-3">
      <span class={`text-xs font-semibold uppercase tracking-widest px-2.5 py-1 rounded-full border ${categoryColor[category]}`}>
        {categoryLabel[category]}
      </span>
      {readingTime && (
        <span class="text-xs text-gray-500">{readingTime} min</span>
      )}
    </div>

    <h2 class="text-lg font-bold text-white mb-2 leading-snug group-hover:text-sky-300 transition-colors line-clamp-2">
      {title}
    </h2>

    <p class="text-sm text-gray-400 leading-relaxed mb-4 line-clamp-3">
      {description}
    </p>

    <div class="flex items-center justify-between">
      <time class="text-xs text-gray-500" datetime={pubDate.toISOString()}>
        {formatDate(pubDate)}
      </time>
      <span class="text-xs text-sky-400 font-medium group-hover:gap-2 flex items-center gap-1 transition-all">
        Ler artigo
        <svg class="w-3.5 h-3.5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </span>
    </div>
  </div>
</a>
