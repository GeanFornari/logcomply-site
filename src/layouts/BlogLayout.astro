---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import CTAContextual from '../components/CTAContextual.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author?: string;
  category: 'journey-comply' | 'aisbr' | 'kontrolsub' | 'aviacao';
  tags: string[];
  image?: { src: string; alt: string };
  relatedProduct?: 'journey-comply' | 'aisbr' | 'kontrolsub';
  rawContent?: string;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  author = 'Equipe Vektor Aero',
  category,
  tags,
  image,
  relatedProduct,
  rawContent = '',
} = Astro.props;

const wordCount = rawContent.split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

const categoryLabel: Record<string, string> = {
  'journey-comply': 'Journey Comply',
  'aisbr': 'AIS BR',
  'kontrolsub': 'KontrolSub',
  'aviacao': 'Aviação',
};

const categoryHref: Record<string, string> = {
  'journey-comply': '/blog/journey-comply/',
  'aisbr': '/blog/aisbr/',
  'kontrolsub': '/blog/kontrolsub/',
  'aviacao': '/blog/aviacao/',
};

const formatDate = (date: Date) =>
  date.toLocaleDateString('pt-BR', { day: 'numeric', month: 'long', year: 'numeric' });

const ogImage = image?.src ?? 'https://vektoraero.com.br/og-image.png';

const articleSchema = {
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "author": { "@type": "Organization", "name": author },
  "datePublished": pubDate.toISOString(),
  "dateModified": (updatedDate ?? pubDate).toISOString(),
  "publisher": {
    "@type": "Organization",
    "name": "Vektor Aero",
    "logo": { "@type": "ImageObject", "url": "https://vektoraero.com.br/logo.png" }
  },
  "keywords": tags.join(', '),
  ...(image ? { "image": { "@type": "ImageObject", "url": image.src, "description": image.alt } } : {}),
};
---

<Layout
  title={`${title} — Vektor Aero Blog`}
  description={description}
  ogImage={ogImage}
  schemaType="SoftwareApplication"
  schemaData={articleSchema}
>
  <Header />

  <main class="pt-32 pb-24 min-h-screen">
    <div class="max-w-4xl mx-auto px-4 md:px-8">

      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-gray-400 mb-8" aria-label="Breadcrumb">
        <a href="/" class="hover:text-sky-400 transition-colors">Início</a>
        <span>/</span>
        <a href="/blog/" class="hover:text-sky-400 transition-colors">Blog</a>
        <span>/</span>
        <a href={categoryHref[category]} class="hover:text-sky-400 transition-colors">{categoryLabel[category]}</a>
        <span>/</span>
        <span class="text-gray-300 truncate max-w-xs">{title}</span>
      </nav>

      <!-- Header do artigo -->
      <header class="mb-12">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-xs font-semibold uppercase tracking-widest px-3 py-1 rounded-full bg-sky-500/10 text-sky-400 border border-sky-500/20">
            {categoryLabel[category]}
          </span>
          <span class="text-sm text-gray-400">{readingTime} min de leitura</span>
        </div>

        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white leading-tight mb-6">
          {title}
        </h1>

        <p class="text-lg text-gray-300 leading-relaxed mb-6">{description}</p>

        <div class="flex items-center gap-4 text-sm text-gray-400 pb-8 border-b border-white/10">
          <span>Por <strong class="text-gray-200">{author}</strong></span>
          <span>·</span>
          <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
          {updatedDate && (
            <>
              <span>·</span>
              <span>Atualizado em <time datetime={updatedDate.toISOString()}>{formatDate(updatedDate)}</time></span>
            </>
          )}
        </div>
      </header>

      <!-- Imagem de capa -->
      {image && (
        <div class="mb-12 rounded-2xl overflow-hidden">
          <img
            src={image.src}
            alt={image.alt}
            class="w-full h-64 md:h-96 object-cover"
            loading="eager"
          />
        </div>
      )}

      <!-- Conteúdo do artigo -->
      <article class="prose prose-invert prose-lg max-w-none
        prose-headings:font-bold prose-headings:text-white
        prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-4
        prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
        prose-p:text-gray-300 prose-p:leading-relaxed
        prose-a:text-sky-400 prose-a:no-underline hover:prose-a:underline
        prose-strong:text-white
        prose-code:text-sky-300 prose-code:bg-white/5 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm
        prose-pre:bg-white/5 prose-pre:border prose-pre:border-white/10
        prose-blockquote:border-l-sky-500 prose-blockquote:text-gray-300
        prose-ul:text-gray-300 prose-ol:text-gray-300
        prose-li:marker:text-sky-400
        prose-hr:border-white/10
        prose-img:rounded-xl">
        <slot />
      </article>

      <!-- Tags -->
      {tags.length > 0 && (
        <div class="mt-12 pt-8 border-t border-white/10">
          <div class="flex flex-wrap gap-2">
            {tags.map(tag => (
              <span class="text-xs px-3 py-1.5 rounded-full bg-white/5 text-gray-400 border border-white/10">
                #{tag}
              </span>
            ))}
          </div>
        </div>
      )}

      <!-- CTA Contextual -->
      {relatedProduct && (
        <div class="mt-12">
          <CTAContextual product={relatedProduct} />
        </div>
      )}

    </div>
  </main>

  <!-- Footer simples -->
  <footer class="border-t border-white/10 py-8 text-center text-sm text-gray-500">
    <div class="max-w-7xl mx-auto px-4">
      <p>© {new Date().getFullYear()} Vektor Aero — Todos os direitos reservados.</p>
    </div>
  </footer>
</Layout>
