---
interface Props {
  product: 'journey-comply' | 'aisbr' | 'kontrolsub';
}

const { product } = Astro.props;

const config = {
  'journey-comply': {
    name: 'Journey Comply',
    tagline: 'Gerencie jornadas e fadiga com conformidade RBAC 117 automatizada.',
    href: '/journeycomply/',
    color: 'from-sky-600/20 to-blue-900/20 border-sky-500/30',
    badge: 'bg-sky-500/10 text-sky-300 border-sky-500/20',
    btn: 'bg-sky-500 hover:bg-sky-400',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  },
  'aisbr': {
    name: 'AIS BR',
    tagline: 'NOTAMs, METAR, ROTAER e cartas aeronáuticas no celular, em tempo real.',
    href: '/aisbr/',
    color: 'from-cyan-600/20 to-teal-900/20 border-cyan-500/30',
    badge: 'bg-cyan-500/10 text-cyan-300 border-cyan-500/20',
    btn: 'bg-cyan-500 hover:bg-cyan-400',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064"/></svg>`,
  },
  'kontrolsub': {
    name: 'KontrolSub',
    tagline: 'Visualize, organize e corte gastos com assinaturas digitais em segundos.',
    href: '/kontrolsub/',
    color: 'from-teal-600/20 to-emerald-900/20 border-teal-500/30',
    badge: 'bg-teal-500/10 text-teal-300 border-teal-500/20',
    btn: 'bg-teal-500 hover:bg-teal-400',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>`,
  },
};

const c = config[product];
---

<div class={`rounded-2xl border bg-gradient-to-br p-6 md:p-8 ${c.color}`}>
  <div class="flex flex-col md:flex-row md:items-center gap-6">
    <div class="flex-1">
      <div class={`inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-widest px-3 py-1 rounded-full border mb-4 ${c.badge}`}>
        <Fragment set:html={c.icon} />
        {c.name}
      </div>
      <h3 class="text-xl font-bold text-white mb-2">
        Conheça o {c.name}
      </h3>
      <p class="text-gray-300 text-sm leading-relaxed">
        {c.tagline}
      </p>
    </div>
    <div class="shrink-0">
      <a
        href={c.href}
        class={`inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-white text-sm transition-all duration-200 hover:scale-105 ${c.btn}`}
      >
        Saiba mais
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</div>
