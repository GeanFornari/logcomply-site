---
import { languages } from '../../../i18n/kontrolsub/ui';
import { useTranslations } from '../../../i18n/kontrolsub/utils';
import KontrolSubLayout from '../../../layouts/KontrolSubLayout.astro';
import Header from '../../../components/kontrolsub/Header.astro';
import FeatureCard from '../../../components/kontrolsub/FeatureCard.astro';
import AppMockup from '../../../components/kontrolsub/AppMockup.astro';
import Footer from '../../../components/kontrolsub/Footer.astro';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as keyof typeof languages);
---

<KontrolSubLayout title={t('hero.title')}>
  <Header />

  <main class="pt-32">
    <!-- Hero Section -->
    <section id="inicio" class="relative overflow-hidden px-6 pb-20 pt-10 md:pt-20">
      <div class="absolute -top-24 -left-20 w-96 h-96 bg-accent/10 blur-[120px] rounded-full"></div>
      <div class="absolute top-[40%] -right-20 w-80 h-80 bg-accent/5 blur-[100px] rounded-full"></div>

      <div class="max-w-5xl mx-auto text-center relative z-10">
        <div class="inline-flex items-center gap-2 glass px-4 py-1.5 rounded-full text-xs font-semibold mb-8 text-accent border-accent/20">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-accent"></span>
          </span>
          {t('hero.badge')}
        </div>

        <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-8 leading-[1.1] text-gradient">
          {t('hero.title').split(',')[0]}
          <br class="hidden md:block" />
          <span class="text-accent">{t('hero.title').split(',')[1]}</span>
        </h1>

        <p class="text-lg md:text-xl text-text-secondary max-w-2xl mx-auto mb-10 leading-relaxed">
          {t('hero.subtitle')}
        </p>

        <div class="flex flex-wrap gap-4 justify-center items-center">
          <a href="https://apps.apple.com/app/kontrolsub-subs-tracker/id6760716794" class="transition-transform hover:scale-105 active:scale-95 app-store-link-ks" target="_blank" rel="noopener noreferrer">
            <img src="/kontrolsub/Download_on_the_App_Store_Badge.svg.png" alt="Download on the App Store" class="h-12 md:h-14 w-auto" />
          </a>
          <a href="https://play.google.com/store/apps/details?id=com.vektordigital.kontrol_app&hl=pt_BR" class="transition-transform hover:scale-105 active:scale-95" target="_blank" rel="noopener noreferrer">
            <img src="/kontrolsub/get-it-on-google-play-badge.png" alt="Get it on Google Play" class="h-12 md:h-14 w-auto" />
          </a>
        </div>

        <!-- Hero Mockup -->
        <div class="mt-20 max-w-[300px] md:max-w-[420px] mx-auto relative group animate-float">
          <div class="absolute -inset-4 bg-accent/20 blur-3xl rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
          <div class="relative glass-dark rounded-[3rem] p-3 shadow-2xl overflow-hidden border border-white/10 hover:border-accent/30 transition-all duration-500 scale-[0.98] hover:scale-100">
            <img
              src={`/kontrolsub/app/${lang}/dashboard.png`}
              alt={t('hero.mockup_alt')}
              class="rounded-[2.2rem] w-full h-auto object-cover"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section id="funcionalidades" class="py-24 px-6 md:px-12 bg-white/[0.02]">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-5xl font-bold mb-4">{t('features.title')}</h2>
          <p class="text-text-secondary">{t('features.subtitle')}</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <FeatureCard icon="🔔" title={t('feature1.title')} description={t('feature1.desc')} />
          <FeatureCard icon="📊" title={t('feature2.title')} description={t('feature2.desc')} />
          <FeatureCard icon="⚡" title={t('feature3.title')} description={t('feature3.desc')} />
          <FeatureCard icon="📅" title={t('feature4.title')} description={t('feature4.desc')} />
          <FeatureCard icon="📖" title={t('feature5.title')} description={t('feature5.desc')} />
          <FeatureCard icon="☁️" title={t('feature6.title')} description={t('feature6.desc')} />
        </div>
      </div>
    </section>

    <!-- Product Showcase -->
    <section class="py-24 px-6 md:px-12">
      <div class="max-w-7xl mx-auto">
        <AppMockup
          src={`/kontrolsub/app/${lang}/analytics.png`}
          alt={t('product.mockup_alt')}
          caption={t('product.caption')}
          reverse={false}
        >
          <h2 class="text-3xl md:text-5xl font-bold mb-6">{t('product.title')}</h2>
          <p class="text-lg text-text-secondary leading-relaxed">{t('product.desc')}</p>
          <ul class="space-y-4 mt-8">
            <li class="flex items-center gap-3">
              <div class="w-6 h-6 rounded-full bg-accent/20 flex items-center justify-center text-accent">✓</div>
              <span>{t('product.list1')}</span>
            </li>
            <li class="flex items-center gap-3">
              <div class="w-6 h-6 rounded-full bg-accent/20 flex items-center justify-center text-accent">✓</div>
              <span>{t('product.list2')}</span>
            </li>
          </ul>
        </AppMockup>
      </div>
    </section>
  </main>

  <Footer />
</KontrolSubLayout>

<script is:inline>
  function setupStoreRedirection() {
    // Redirecionamento App Store (iOS)
    const appStoreConfigs = [
      { selector: '.app-store-link-ks', appId: 'id6760716794', path: '/app/kontrolsub-subs-tracker/id6760716794' }
    ];

    appStoreConfigs.forEach(config => {
      const links = document.querySelectorAll(config.selector);
      links.forEach(link => {
        link.addEventListener('click', function(e) {
          const isIOS = /iPhone|iPad|iPod/i.test(navigator.userAgent);

          if (isIOS) {
            e.preventDefault();
            window.location.href = `itms-apps://apps.apple.com${config.path}`;

            setTimeout(() => {
              window.location.href = `https://apps.apple.com${config.path}`;
            }, 500);
          }
        });
      });
    });
  }

  // Executa na carga inicial
  setupStoreRedirection();

  // Compatibilidade com View Transitions do Astro (se habilitado)
  document.addEventListener('astro:page-load', setupStoreRedirection);
</script>

<style>
  .glass-dark {
    background: linear-gradient(135deg, rgba(34, 58, 58, 0.4) 0%, rgba(21, 38, 38, 0.6) 100%);
  }
</style>
