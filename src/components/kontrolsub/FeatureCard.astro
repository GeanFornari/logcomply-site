---
interface Props {
  icon: string;
  title: string;
  description: string;
}

const { icon, title, description } = Astro.props;
---

<div class="glass-dark p-8 rounded-3xl border-white/10 hover:border-accent/30 transition-all hover:scale-[1.02] group">
  <div class="w-14 h-14 bg-accent/10 rounded-2xl flex items-center justify-center text-accent mx-auto mb-6 text-2xl group-hover:bg-accent/20 transition-colors">
    {icon}
  </div>
  <h3 class="text-xl font-bold mb-3">{title}</h3>
  <p class="text-text-secondary text-sm leading-relaxed">{description}</p>
</div>
