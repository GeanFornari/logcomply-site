<!-- Contém código gerado por IA -->
<header id="main-header-jc" class="fixed top-0 left-0 w-full z-50 py-4 px-4 md:px-8 transition-all duration-300">
  
  <div id="header-container-jc" class="mx-auto flex max-w-7xl items-center justify-between p-4 glass-white rounded-2xl shadow-xl transition-all duration-300 relative">
    
    <a href="/" class="flex items-center gap-4 transition-transform hover:scale-105">
      <img src="/logo.png" alt="Vektor Aero Logo" class="h-10 sm:h-12 w-auto" />
      <span class="hidden sm:block text-xl md:text-2xl font-bold ethnocentric-font text-blue-900">
        VEKTOR AERO
      </span>
    </a>

    <div class="flex items-center gap-6">
      
      <nav class="hidden md:flex items-center gap-6 text-lg font-semibold text-gray-700">
        <a href="#sobre" class="hover:text-sky-500 transition-colors">Sobre</a>
        <a href="#funcionalidades" class="hover:text-sky-500 transition-colors">Funcionalidades</a>
        <a href="#contato" class="hover:text-sky-500 transition-colors">Contato</a>
      </nav>

      <div class="md:hidden">
        <button id="menu-btn-jc" aria-label="Abrir menu" class="text-gray-800 focus:outline-none p-2 rounded-lg hover:bg-black/5 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
          </svg>
        </button>
      </div>

    </div>
  </div>

  <div id="mobile-menu-jc" class="hidden md:hidden absolute top-[calc(100%-1rem)] left-4 right-4 bg-white/95 backdrop-blur-lg rounded-2xl shadow-2xl border border-gray-100 mt-2 overflow-hidden">
    <nav class="flex flex-col items-center space-y-4 p-8 text-lg font-semibold text-gray-700">
      <a href="#sobre" class="hover:text-sky-500">Sobre</a>
      <a href="#funcionalidades" class="hover:text-sky-500">Funcionalidades</a>
      <a href="#contato" class="hover:text-sky-500">Contato</a>
    </nav>
  </div>

</header>

<script>
  const header = document.getElementById('main-header-jc');
  const container = document.getElementById('header-container-jc');
  const menuBtnJc = document.getElementById('menu-btn-jc');
  const mobileMenuJc = document.getElementById('mobile-menu-jc');

  // Scroll effect
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      header?.classList.remove('py-4');
      header?.classList.add('py-2');
      container?.classList.add('p-2', 'px-6');
      container?.classList.remove('p-4');
    } else {
      header?.classList.add('py-4');
      header?.classList.remove('py-2');
      container?.classList.add('p-4');
      container?.classList.remove('p-2', 'px-6');
    }
  });

  // Mobile menu functionality
  if (menuBtnJc && mobileMenuJc) {
    const mobileMenuLinks = mobileMenuJc.querySelectorAll('a');

    menuBtnJc.addEventListener('click', () => {
      mobileMenuJc.classList.toggle('hidden');
    });

    mobileMenuLinks.forEach(link => {
      link.addEventListener('click', () => {
        mobileMenuJc.classList.add('hidden');
      });
    });

    // Close on click outside
    document.addEventListener('click', (e) => {
      if (!menuBtnJc.contains(e.target as Node) && !mobileMenuJc.contains(e.target as Node)) {
        mobileMenuJc.classList.add('hidden');
      }
    });
  }
</script>

