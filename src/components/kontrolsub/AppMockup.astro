---
interface Props {
  src: string;
  alt: string;
  caption?: string;
  reverse?: boolean;
}

const { src, alt, caption, reverse = false } = Astro.props;
---

<div class={`flex flex-col md:flex-row items-center gap-12 py-12 ${reverse ? 'md:flex-row-reverse' : ''}`}>
  <div class="flex-[0.7] md:flex-[0.8] relative group max-w-[320px] md:max-w-[380px]">
    <div class="absolute -inset-4 bg-accent/20 blur-3xl rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
    <div class="relative glass-dark rounded-[3rem] p-3 shadow-2xl overflow-hidden border border-white/10 hover:border-accent/30 transition-all duration-500 scale-[0.98] hover:scale-100">
      <img src={src} alt={alt} class="rounded-[2.5rem] w-full h-auto object-cover" loading="lazy" />
    </div>
  </div>

  <div class="flex-1 md:flex-[1.2] space-y-6">
    {caption && (
      <div class="inline-block px-4 py-1.5 rounded-full bg-accent/10 border border-accent/20 text-accent text-xs font-bold tracking-wider uppercase">
        {caption}
      </div>
    )}
    <slot />
  </div>
</div>

<style>
  .glass-dark {
    background: linear-gradient(135deg, rgba(34, 58, 58, 0.4) 0%, rgba(21, 38, 38, 0.6) 100%);
  }
</style>
